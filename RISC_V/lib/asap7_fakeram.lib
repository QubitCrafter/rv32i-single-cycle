/* =============================================================================
   asap7_fakeram.lib
   Behavioural SRAM Timing Model for the ASAP7 7nm Predictive PDK
   =============================================================================
  
   ORIGIN
     This file was generated by Antigravity, an AI coding assistant developed
     by the Google DeepMind team. It was not produced by a foundry, an SRAM
     compiler, or any official ASAP7 toolchain.
  
   PURPOSE
     The ASAP7 PDK does not ship with compiled SRAM macros. This file provides
     a hand-crafted Liberty (.lib) timing model for the InstructionMem and
     DataMem modules so that Yosys and OpenSTA can:
       - Treat both memories as black-box macros (not synthesise their internals)
       - Apply realistic 7nm SRAM access delays to the timing paths
         (InstructionMem: 75 ps access, DataMem: 85 ps access)
       - Report area contributions from the macros
  
   TIMING VALUES
     Access delays were chosen based on published SRAM characterisation data
     for sub-10nm nodes (typical 6T-SRAM read latency ≈ 50–100 ps at 7nm TT).
     They are approximations for academic purposes and should NOT be used for
     any real tapeout or sign-off analysis.
  
   LICENSE
     This file is released into the public domain (CC0 1.0 Universal).
     You are free to use, copy, modify, and distribute it for any purpose
     without restriction and without any warranty.
  
   =============================================================================
*/

library(asap7_fakeram) {

  time_unit : "1ps";
  voltage_unit : "1V";
  current_unit : "1mA";
  pulling_resistance_unit : "1kohm";
  leakage_power_unit : "1nW";
  capacitive_load_unit : "1pf";

  type (bus32) {
    base_type : array;
    data_type : bit;
    bit_width : 32;
    bit_from : 31;
    bit_to : 0;
  }

  cell(InstructionMem) {
    area : 1500.0;
    
    bus(PC) {
      bus_type : bus32;
      direction : input;
      capacitance : 1.0;
    }
    
    bus(instruction) {
      bus_type : bus32;
      direction : output;
      timing() {
        related_pin : "PC";
        timing_type : combinational;
        intrinsic_rise : 75.0;
        intrinsic_fall : 75.0;
      }
    }
  }

  cell(DataMem) {
    area : 3000.0;
    
    pin(clk) { direction : input; }
    pin(mem_read) { direction : input; capacitance : 0.5; }
    pin(mem_write) { direction : input; capacitance : 0.5; }
    
    bus(address) {
      bus_type : bus32;
      direction : input;
      capacitance : 1.0;
      timing() {
        related_pin : "clk";
        timing_type : setup_rising;
        intrinsic_rise : 25.0;
        intrinsic_fall : 25.0;
      }
      timing() {
        related_pin : "clk";
        timing_type : hold_rising;
        intrinsic_rise : 5.0;
        intrinsic_fall : 5.0;
      }
    }
    
    bus(write_data) {
      bus_type : bus32;
      direction : input;
      capacitance : 1.0;
      timing() {
        related_pin : "clk";
        timing_type : setup_rising;
        intrinsic_rise : 25.0;
        intrinsic_fall : 25.0;
      }
      timing() {
        related_pin : "clk";
        timing_type : hold_rising;
        intrinsic_rise : 5.0;
        intrinsic_fall : 5.0;
      }
    }
    
    bus(read_data) {
      bus_type : bus32;
      direction : output;
      timing() {
        related_pin : "address";
        timing_type : combinational;
        intrinsic_rise : 85.0;
        intrinsic_fall : 85.0;
      }
      timing() {
        related_pin : "mem_read";
        timing_type : combinational;
        intrinsic_rise : 20.0;
        intrinsic_fall : 20.0;
      }
    }
  }
}
